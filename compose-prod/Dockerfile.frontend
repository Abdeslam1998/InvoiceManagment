# syntax=docker/dockerfile:1.7

############################
# Frontend build
############################
FROM node:20-alpine AS frontend-build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY angular.json ./
COPY tsconfig*.json ./
COPY tailwind.config.js ./
COPY src ./src
COPY public ./public
RUN npm run build -- --configuration production

############################
# Frontend runtime (Nginx)
############################
FROM nginx:1.27-alpine AS frontend-runtime
# Copy custom nginx config
RUN printf 'server {\n  listen 80;\n  server_name _;\n  root /usr/share/nginx/html;\n  index index.html;\n\n  location / {\n    try_files $uri $uri/ /index.html;\n  }\n\n  # Serve environment variables\n  location /assets/env.js {\n    add_header Content-Type application/javascript;\n    return 200 "window.env = { API_URL: '\''${API_URL:-http://localhost:3000/api}'\'' }";\n  }\n}\n' > /etc/nginx/conf.d/default.conf
COPY --from=frontend-build /app/dist/pristine-flow/browser /usr/share/nginx/html
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]